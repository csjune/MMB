import { Button, ScrollView, Slider } from "std-widgets.slint";

global AppPalette {
    in-out property <bool> dark-mode;
    out property <brush> foreground: dark-mode ? #f5f5f5 : #1f1f1f;
    out property <brush> muted-foreground: dark-mode ? #c8c8c8 : #666666;
    out property <brush> window-background: dark-mode ? #202020 : #f3f3f3;
    out property <brush> window-border: dark-mode ? #606060 : #8a8a8a;
    out property <brush> divider: dark-mode ? #3a3a3a : #d0d0d0;
    out property <brush> tick: dark-mode ? #FFFFFF14 : #00000073;
    out property <brush> checked-foreground: #ffffff;
}

export global PopupMetrics {
    out property <length> window-width: 348px;
    out property <length> min-window-height: 148px;
    out property <length> max-window-height: 560px;
    out property <length> chrome-height: 75px;
    out property <length> empty-body-height: 104px;
    out property <length> monitor-row-height: 70px;
    out property <length> monitor-row-spacing: 12px;
    out property <length> content-padding: 14px;
    out property <length> body-padding: 10px;
    out property <length> footer-height: 54px;
    out property <length> divider-height: 1px;
    out property <length> button-size: 32px;
    out property <length> content-width: window-width - content-padding * 2;
}

export struct MonitorEntry {
    id: int,
    name: string,
    brightness: int,
}

component BrightnessSlider inherits Rectangle {
    in property <int> value;

    callback changed(float);
    callback scrolled(int);

    height: 34px;
    background: transparent;

    private property <length> thumb-size: 20px;
    private property <length> slider-height: 24px;
    private property <length> track-width: max(1px, root.width - root.thumb-size);
    private property <length> tick-width: 2px;
    private property <length> tick-height: 7px;
    private property <length> tick-y: 26px;

    Rectangle {
        x: root.tick-x(0);
        y: root.tick-y;
        width: root.tick-width;
        height: root.tick-height;
        background: AppPalette.tick;
    }

    Rectangle {
        x: root.tick-x(25);
        y: root.tick-y;
        width: root.tick-width;
        height: root.tick-height;
        background: AppPalette.tick;
    }

    Rectangle {
        x: root.tick-x(50);
        y: root.tick-y;
        width: root.tick-width;
        height: root.tick-height;
        background: AppPalette.tick;
    }

    Rectangle {
        x: root.tick-x(75);
        y: root.tick-y;
        width: root.tick-width;
        height: root.tick-height;
        background: AppPalette.tick;
    }

    Rectangle {
        x: root.tick-x(100);
        y: root.tick-y;
        width: root.tick-width;
        height: root.tick-height;
        background: AppPalette.tick;
    }

    Slider {
        width: parent.width;
        height: root.slider-height;
        minimum: 0;
        maximum: 100;
        step: 1;
        value: root.value;

        changed(value) => {
            root.changed(value);
        }
    }

    touch := TouchArea {
        scroll-event(event) => {
            root.scrolled(event.delta-y > 0px ? 5 : -5);
            return EventResult.accept;
        }

        pointer-event(event) => {
            if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                root.changed(root.position-to-value(touch.mouse-x - root.thumb-size / 2, root.track-width));
            }
        }

        moved => {
            root.changed(root.position-to-value(touch.mouse-x - root.thumb-size / 2, root.track-width));
        }
    }

    pure function position-to-value(position: length, range: length) -> float {
        if range <= 0px {
            return 0;
        }

        return max(0, min(100, position * 100 / range));
    }

    pure function tick-x(value: float) -> length {
        return root.thumb-size / 2 + root.track-width * value / 100 - root.tick-width / 2;
    }
}

component MonitorRow inherits Rectangle {
    in property <int> monitor-id;
    in property <string> name;
    in property <int> brightness;

    callback brightness-changed(float);
    callback brightness-scrolled(int);

    height: PopupMetrics.monitor-row-height;
    background: transparent;

    private property <length> track-inset: 10px;

    VerticalLayout {
        spacing: 6px;

        HorizontalLayout {
            height: 24px;
            spacing: 0px;

            Rectangle {
                width: root.track-inset;
                background: transparent;
            }

            Text {
                text: root.name;
                color: AppPalette.foreground;
                font-size: 14px;
                horizontal-stretch: 1;
                overflow: elide;
                vertical-alignment: center;
            }

            Rectangle {
                width: root.track-inset;
                background: transparent;
            }
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;

            BrightnessSlider {
                horizontal-stretch: 1;
                value: root.brightness;

                changed(value) => {
                    root.brightness-changed(value);
                }

                scrolled(delta) => {
                    root.brightness-scrolled(delta);
                }
            }

            Text {
                text: "\{root.brightness}";
                color: AppPalette.foreground;
                font-size: 14px;
                width: 30px;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            Rectangle {
                width: 4px;
                background: transparent;
            }
        }
    }
}

component IconButton inherits Rectangle {
    callback clicked();

    in property <string> symbol;
    in property <bool> checkable: false;
    in property <length> icon-x: 0px;
    in property <length> icon-y: 0px;
    in-out property <bool> checked;

    width: PopupMetrics.button-size;
    height: PopupMetrics.button-size;
    background: transparent;

    Button {
        width: parent.width;
        height: parent.height;
        text: "";
        checkable: root.checkable;
        checked <=> root.checked;

        clicked => {
            root.clicked();
        }
    }

    Text {
        x: root.icon-x;
        y: root.icon-y;
        text: root.symbol;
        color: root.checked ? AppPalette.checked-foreground : AppPalette.foreground;
        font-family: "Segoe Fluent Icons";
        font-size: 20px;
        width: parent.width;
        height: parent.height;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MainWindow inherits Window {
    in property <image> app-icon;
    in-out property <[MonitorEntry]> monitors;
    in-out property <bool> sync-all;
    in-out property <bool> dark-mode <=> AppPalette.dark-mode;
    in property <bool> has-monitors;
    in property <length> body-height: 104px;

    callback brightness-changed(int, float);
    callback brightness-scrolled(int, int);
    callback refresh-requested();
    callback theme-toggle-requested();

    title: "MMB";
    icon: root.app-icon;
    preferred-width: PopupMetrics.window-width;
    preferred-height: 180px;
    min-width: PopupMetrics.window-width;
    max-width: PopupMetrics.window-width;
    min-height: PopupMetrics.min-window-height;
    max-height: PopupMetrics.max-window-height;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    Rectangle {
        width: PopupMetrics.window-width;
        height: parent.height;
        background: AppPalette.window-background;
        border-color: AppPalette.window-border;
        border-width: 1px;
        border-radius: 8px;

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                height: root.body-height + PopupMetrics.body-padding * 2;
                background: transparent;

                if root.has-monitors : ScrollView {
                    x: PopupMetrics.content-padding;
                    y: PopupMetrics.body-padding;
                    width: PopupMetrics.content-width;
                    height: root.body-height;
                    viewport-width: PopupMetrics.content-width;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                    VerticalLayout {
                        padding: 0px;
                        spacing: PopupMetrics.monitor-row-spacing;

                        for monitor in root.monitors : MonitorRow {
                            width: PopupMetrics.content-width;
                            monitor-id: monitor.id;
                            name: monitor.name;
                            brightness: monitor.brightness;

                            brightness-changed(value) => {
                                root.brightness-changed(monitor.id, value);
                            }

                            brightness-scrolled(delta) => {
                                root.brightness-scrolled(monitor.id, delta);
                            }
                        }
                    }
                }

                if !root.has-monitors : Rectangle {
                    x: PopupMetrics.content-padding;
                    y: PopupMetrics.body-padding;
                    width: PopupMetrics.content-width;
                    height: root.body-height;
                    background: transparent;

                    Text {
                        width: PopupMetrics.content-width;
                        y: (parent.height - self.height) / 2;
                        text: "No adjustable monitors found.";
                        color: AppPalette.muted-foreground;
                        font-size: 14px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }

            Rectangle {
                width: PopupMetrics.window-width;
                height: PopupMetrics.divider-height;
                background: AppPalette.divider;
            }

            Rectangle {
                height: PopupMetrics.footer-height;
                background: transparent;

                HorizontalLayout {
                    x: PopupMetrics.content-padding;
                    y: PopupMetrics.body-padding;
                    width: PopupMetrics.content-width;
                    height: 30px;
                    spacing: 8px;

                    Rectangle {
                        background: transparent;
                        horizontal-stretch: 1;
                    }

                    IconButton {
                        symbol: "\u{e71b}";
                        icon-x: 1px;
                        icon-y: 1px;
                        checkable: true;
                        checked <=> root.sync-all;
                    }

                    IconButton {
                        symbol: root.dark-mode ? "\u{e706}" : "\u{e708}";
                        icon-x: 1px;

                        clicked => {
                            root.theme-toggle-requested();
                        }
                    }

                    IconButton {
                        symbol: "\u{e72c}";
                        icon-x: 1px;
                        icon-y: 1px;

                        clicked => {
                            root.refresh-requested();
                        }
                    }
                }
            }
        }
    }
}

export component TrayIcon inherits SystemTrayIcon {
    in property <image> app-icon;

    icon: root.app-icon;
    tooltip: "MMB";
    title: "MMB";

    clicked => {
        root.toggle-window();
    }

    callback toggle-window();
    callback quit-requested();

    Menu {
        MenuItem {
            title: "Show/Hide";
            activated => {
                root.toggle-window();
            }
        }

        MenuSeparator {}

        MenuItem {
            title: "Quit";
            activated => {
                root.quit-requested();
            }
        }
    }
}
